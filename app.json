{
  "expo": {
    "name": "cubanos",
    "slug": "cubanos",
    "scheme": "cubanos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cubanos.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0a08",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.cubanos.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Cubanos",
      "shortName": "Cubanos",
      "description": "App premium de colecionadores de charutos e whisky",
      "themeColor": "#EF9F27",
      "backgroundColor": "#0d0a08"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "backgroundColor": "#0d0a08"
        }
      ],
      "expo-font",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app acessa suas fotos para identificar charutos.",
          "cameraPermission": "O app usa a câmera para fotografar a anilha do charuto."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O app usa sua localização para ordenar os Lounges por proximidade."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
